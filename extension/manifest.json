{
  "manifest_version": 3,
  "name": "Verifi.ai",
  "version": "1.0",
  "description": "AI News Credibility Assistant",

  "permissions": ["activeTab", "storage"],

  "action": {
    "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ]
}